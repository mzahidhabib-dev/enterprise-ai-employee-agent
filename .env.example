# ==============================================================
# AI Employee Agent - Environment Variables Configuration
# ==============================================================

# 1. Core API Keys
AGENT_API_KEY=your_secure_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Database & Redis Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/ai_agent_db
REDIS_URL=redis://localhost:6379/0

# 3. Third-Party Tool Credentials
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# 4. Observability & Tracing (LangSmith)
# --------------------------------------------------------------
# STEP 6.1 (Observability): LangSmith deep dive
# Set LANGCHAIN_TRACING_V2=true to automatically trace every
# LangChain/LangGraph execution with zero code changes.
# It captures: node latency, input/output tokens, and cost.
# --------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=ai_employee_agent

# STEP 6.4: Daily Cost Alert Threshold
# Sends a Slack alert if daily LLM cost exceeds this value
COST_ALERT_THRESHOLD_USD=5.0
